### --- Airflow : image & utilisateur ---
AIRFLOW_UID=50000
AIRFLOW_IMAGE_NAME=apache/airflow:3.2.2
AIRFLOW_PORT=8080

### --- Airflow : secrets ---
# Fernet key (chiffre les mots de passe stockés dans les Connections Airflow).
# Génère-la avec :
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=

# JWT secret (auth interne entre l'API server, le scheduler, etc.).
# Génère-le avec :
#   openssl rand -hex 32
AIRFLOW_JWT_SECRET=

### --- Airflow : utilisateur admin créé au premier démarrage ---
_AIRFLOW_WWW_USER_USERNAME=admin
_AIRFLOW_WWW_USER_PASSWORD=changeme
_AIRFLOW_WWW_USER_FIRSTNAME=Admin
_AIRFLOW_WWW_USER_LASTNAME=User
_AIRFLOW_WWW_USER_EMAIL=admin@example.com

# Dépendances pip supplémentaires à installer au démarrage des conteneurs
# (déconseillé en prod, pratique pour des tests rapides). Laisser vide sinon.
_PIP_ADDITIONAL_REQUIREMENTS=

### --- Postgres réservé à Airflow (ne pas toucher) ---
POSTGRES_IMAGE=postgres:18
POSTGRES_USER=airflow
POSTGRES_PASSWORD=changeme
POSTGRES_DB=airflow
POSTGRES_PORT=5432

### --- Postgres dédié à ton projet data ---
DATA_POSTGRES_IMAGE=postgres:18
DATA_POSTGRES_USER=data_user
DATA_POSTGRES_PASSWORD=changeme
DATA_POSTGRES_DB=data_db
DATA_POSTGRES_PORT=5433
